 cd /run/media/sofi/Study/A-multi-tenant-SaaS-platform-for-shop-management/frontend && cat << 'EOF' > clean_css.js
const fs = require('fs');
let css = fs.readFileSync('src/styles/app.css', 'utf-8');

// remove old profile-cover
css = css.replace(/\.profile-cover\s*{[^}]*}/g, '');
css = css.replace(/\.cover-pattern\s*{[^}]*}/g, '');

// save
fs.writeFileSync('src/styles/app.css', css);
EOF
